// ==========================================
// AI CONCIERGE & CHAT HISTORY MODELS
// ==========================================

model AiChatSession {
  id               String          @id @default(uuid())
  userId           String
  title            String?
  status           String          @default("ACTIVE")
  sessionType      String          @default("PARENT")
  humanRequested   Boolean         @default(false)
  humanJoinedAt    DateTime?
  humanAgentId     String?
  providerId       String?
  providerJoinedAt DateTime?
  providerName     String?
  profilePhotoUrl  String?
  subjectProfileId String?
  subjectType      String?
  matchmakerId     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  messages      AiChatMessage[]
  silentQueries SilentQuery[]
  agreements    Agreement[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      Provider?       @relation(fields: [providerId], references: [id])

  @@index([userId])
  @@index([humanRequested])
  @@index([providerId])
  @@index([sessionType])
  @@index([providerId, subjectProfileId])
}

model AiChatMessage {
  id          String        @id @default(uuid())
  sessionId   String
  role        String
  content     String
  senderType  String        @default("ai")
  senderName  String?
  uiCardType  String?
  uiCardData  Json?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime      @default(now())

  session     AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ==========================================
// INTENDED PARENT AI PROFILE & PREFERENCES
// ==========================================

model IntendedParentProfile {
  id                  String        @id @default(uuid())
  parentAccountId     String        @unique
  
  interestedServices  String[]      @default([])
  journeyStage        String?       
  
  // Biological Matrix
  hasEmbryos          Boolean       @default(false)
  embryoCount         Int           @default(0)
  embryosTested       Boolean       @default(false)
  eggSource           String?       
  spermSource         String?       
  carrier             String?       

  // Service-Specific Preferences
  clinicReason        String?
  clinicPriority      String?
  donorEyeColor       String?
  donorHairColor      String?
  donorHeight         String?
  donorEducation      String?
  donorEthnicity      String?
  surrogateBudget     String?
  surrogateMedPrefs   String?

  // Needs flags (set during conversation)
  needsSurrogate      Boolean       @default(false)
  needsEggDonor       Boolean       @default(false)
  needsClinic         Boolean       @default(false)

  // Surrogate preferences
  surrogateTwins       String?
  surrogateCountries   String?
  surrogateTermination String?
  surrogateAgeRange    String?
  surrogateExperience  String?

  // Donor preferences (open-ended from AI conversation)
  donorPreferences     String?
  spermDonorType       String?

  // IVF history
  isFirstIvf           Boolean?

  // Lead Status
  hotLeadProviderId   String?
  hotLeadAt           DateTime?

  // Current Professionals Network
  currentClinicName   String?
  currentAgencyName   String?
  currentAttorneyName String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  parentAccount       ParentAccount @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
}

model JourneyPreferences {
  id                      String        @id @default(uuid())
  parentAccountId         String        @unique
  
  // Cost and Geography
  maxBudget               Int?          
  targetCountries         String[]      @default(["US"]) 
  
  // Deal-breakers
  requiresAbortionSupport Boolean?
  requiresTwinsSupport    Boolean?
  maxSurrogateBmi         Decimal?

  // Clinic Priorities
  preferredPhysicianType  String?       
  clinicPriority          String?       

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  parentAccount           ParentAccount @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
}

model KnowledgeChunk {
  id              String   @id @default(uuid())
  content         String
  metadata        Json?
  embedding       Unsupported("vector(1536)")?
  sourceTier      Int      @default(1)
  providerId      String?
  sourceType      String   @default("DOCUMENT")
  sourceFileName  String?
  sourceUrl       String?
  createdAt       DateTime @default(now())

  provider        Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([sourceTier])
}

model ConciergePromptSection {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  description String?
  content     String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExpertGuidanceRule {
  id        String   @id @default(uuid())
  condition String
  guidance  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SilentQuery {
  id             String   @id @default(uuid())
  parentUserId   String
  providerId     String
  sessionId      String
  questionText   String
  answerText     String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parentUser     User     @relation("SilentQueryParent", fields: [parentUserId], references: [id], onDelete: Cascade)
  provider       Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  session        AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([providerId, status])
  @@index([parentUserId, status])
  @@index([sessionId])
}

// ==========================================
// PANDADOC AGREEMENT TRACKING
// ==========================================

model Agreement {
  id                  String        @id @default(uuid())
  providerId          String
  parentUserId        String
  sessionId           String
  pandaDocDocumentId  String?       @unique
  pandaDocViewUrl     String?
  status              String        @default("DRAFT")
  documentType        String        @default("Agency Agreement")
  signedAt            DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  provider            Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  parentUser          User          @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  session             AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([parentUserId])
  @@index([sessionId])
}